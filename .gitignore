# ===== PHP / Laravel (backend) =====
/backend/vendor/
/backend/.env
/backend/.env.*
!/backend/.env.example
/backend/storage/logs/*
/backend/storage/framework/cache/*
/backend/storage/framework/sessions/*
/backend/storage/framework/views/*
/backend/storage/app/public/*
/backend/public/storage
/backend/public/hot
/backend/bootstrap/cache/*
/backend/database/*.sqlite
/backend/database/*.sqlite-journal
# DB dumps are point-in-time snapshots (customer data, go stale fast) — transferred as a
# file to the devs, never committed. The dumps/README explains how to (re)generate one.
/backend/database/dumps/*.sql

# keep the (otherwise-empty) runtime dirs so the Docker build / fresh clones have them
!/backend/storage/logs/.gitkeep
!/backend/storage/framework/cache/.gitkeep
!/backend/storage/framework/sessions/.gitkeep
!/backend/storage/framework/views/.gitkeep
!/backend/storage/app/public/.gitkeep
!/backend/bootstrap/cache/.gitkeep

# ===== Node / Vite (frontend) =====
/frontend/node_modules/
/frontend/dist/
/frontend/.env
/frontend/.env.*
!/frontend/.env.example
/frontend/vite.log

# ===== misc =====
.DS_Store
Thumbs.db
*.log
auditor/*
.claude/*
# big local-only sample drawings
/assets/*.pdf
/assets/*.png
.gstack/
