APP_NAME="Epic Craftings Quote Generator"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Local dev = XAMPP MySQL. Defaults below match a stock XAMPP install (root, no password)
# and the database name in the provided dump (backend/database/dumps/epic-quote-estimator.sql).
# Keep the name lowercase — MySQL is case-sensitive for DB names on Linux/Mac.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=epic-quote-estimator
DB_USERNAME=root
DB_PASSWORD=

# Laravel Sanctum — Vite dev server runs on 5180 in this project (see vite.config)
SANCTUM_STATEFUL_DOMAINS=localhost:5180,localhost:5173,localhost:3000

# Storage — swap FILESYSTEM_DISK to s3 for R2 (no other changes needed)
FILESYSTEM_DISK=local

# S3/R2 (fill when switching from Render disk to Cloudflare R2)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true

# Groq AI
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Gotenberg — server-side PDF
GOTENBERG_URL=http://localhost:3030

# Real-time (Laravel WebSockets or Reverb)
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=epic-craftings
PUSHER_APP_KEY=epic-craftings-key
PUSHER_APP_SECRET=
PUSHER_HOST=127.0.0.1
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_APP_CLUSTER=mt1

# Seed passwords (set before first boot. Any left blank → strong random generated
# and printed once during `php artisan db:seed`.)
SEED_ADMIN_PASSWORD=
SEED_ROD_PASSWORD=
SEED_ED_PASSWORD=
SEED_SAMI_PASSWORD=
SEED_ALISHAN_PASSWORD=
SEED_FARAZ_PASSWORD=
SEED_MUSAVIR_PASSWORD=
SEED_KHOLA_PASSWORD=
SEED_KHANSA_PASSWORD=
SEED_USMANALTAF_PASSWORD=

# Shopify payment links (set in Render secrets to go live)
SHOPIFY_STORE_DOMAIN=
SHOPIFY_API_TOKEN=
SHOPIFY_API_VERSION=2025-01
SHOPIFY_LOCATION_ID=
SHOPIFY_WEBHOOK_SECRET=
